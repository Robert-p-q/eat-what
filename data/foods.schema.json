{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "foods.schema.json",
  "title": "食堂菜品列表",
  "description": "根节点为数组，每项为一道菜。修改后保存即可被页面加载。",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": true,
    "required": ["canteen", "floor", "stall", "name", "price", "tags"],
    "properties": {
      "canteen": {
        "type": "string",
        "minLength": 1,
        "description": "食堂名称，需与页面下拉选项一致（如一食堂、二食堂）"
      },
      "floor": {
        "type": "string",
        "minLength": 1
      },
      "stall": {
        "type": "string",
        "minLength": 1
      },
      "name": {
        "type": "string",
        "minLength": 1
      },
      "price": {
        "type": "number",
        "description": "单价（元），可为小数"
      },
      "tags": {
        "type": "array",
        "items": { "type": "string", "minLength": 1 }
      },
      "image": {
        "type": "string",
        "description": "菜品图片路径（可选），如 images/兰州牛肉面-尖椒牛肉拌面.jpg；缺省或不填则不显示图片"
      },
      "category": {
        "type": "string",
        "enum": ["main", "side", "snack", "drink"],
        "default": "main",
        "description": "主食(main) / 配菜(side) / 小吃(snack) / 饮品(drink)；缺省视为 main，仅 main 进入推荐池"
      }
    }
  }
}
